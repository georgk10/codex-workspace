# Track only the portable workspace framework. Everything else is local state.
/*

!/.gitignore
!/AGENTS.md
!/README.md
!/workspace.example.toml

!/scripts/
/scripts/*
!/scripts/init-workspace
!/scripts/render-repos

!/templates/
/templates/*
!/templates/MEMORY.md
!/templates/REPOS.md

!/.codex/
/.codex/*
!/.codex/config.toml
!/.codex/agents/
/.codex/agents/*
!/.codex/agents/*.toml

!/.agents/
/.agents/*
!/.agents/skills/
/.agents/skills/*
!/.agents/skills/reflect-and-compact/
/.agents/skills/reflect-and-compact/*
!/.agents/skills/reflect-and-compact/SKILL.md
!/.agents/skills/reflect-and-compact/agents/
/.agents/skills/reflect-and-compact/agents/*
!/.agents/skills/reflect-and-compact/agents/openai.yaml
